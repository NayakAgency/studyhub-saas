# ============================================================
# StudyHub Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Backend API base URL (no trailing slash)
# Development: leave blank (Vite proxy handles /api → localhost:3001)
# Production:  set to your Railway/Render backend URL
VITE_API_URL=

# WebSocket URL (auto-detected from window.location if blank)
# Production: wss://your-backend.railway.app
VITE_WS_URL=

# Optional: override API host (used to build WS URL)
VITE_API_HOST=
