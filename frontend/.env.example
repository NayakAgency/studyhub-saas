# ============================================================
# StudyHub Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real values.
# ============================================================

# Backend API base URL (no trailing slash)
# Development: leave BLANK — Vite proxy handles /api → localhost:3001
# Production:  your Railway / Render backend URL
VITE_API_URL=https://studyhub-backend.up.railway.app

# WebSocket URL (leave blank to auto-detect from window.location)
# Production: wss://your-backend.up.railway.app
VITE_WS_URL=wss://studyhub-backend.up.railway.app

# Optional: override API host for WS URL construction
VITE_API_HOST=
