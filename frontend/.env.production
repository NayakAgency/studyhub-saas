# Vite production build env — committed intentionally (no secrets here)
# Vercel reads this file automatically when building the frontend project

# Backend API URL — points to studyhub-api Vercel project
VITE_API_URL=https://studyhub-api-delta.vercel.app/api

# WebSocket — serverless Vercel backend has no persistent WS
# Leave blank; the app falls back gracefully to polling
VITE_WS_URL=
