# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment variables — NEVER commit secret .env files ───
# Local dev envs (have real secrets)
.env
.env.local
.env.development
.env*.local
backend/.env
frontend/.env

# .env.production files contain build-time public vars (VITE_*)
# and are SAFE to commit — no secrets inside them
# DO NOT add .env.production here

# ── Build outputs ─────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Editor ────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Testing artifacts ─────────────────────────────────────────
coverage/
.nyc_output/
*.pem
.cache/

# ── Supabase local ────────────────────────────────────────────
.branches/
.temp/

# ── Dev test token files ──────────────────────────────────────
.admin_token
.sa_token
.sid
.test_admin_pass
.test_admin_token
.test_plan_id
.test_section_id
.test_tenant_id
.test_token

# NOTE: .vercel folder is intentionally NOT ignored
# It contains project.json (project ID linkage) needed by Vercel CLI
# and GitHub Actions — it has NO secrets.
