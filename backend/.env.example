# ============================================================
# StudyHub Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=generate-a-minimum-32-character-random-string-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Frontend URL — used in notification links and CORS
# Vercel deployment URL (no trailing slash)
APP_URL=https://studyhub.vercel.app
APP_NAME=StudyHub

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://studyhub.vercel.app

# ── Redis Cache ───────────────────────────────────────────────
# Paste your Redis connection URL here when you have it.
# Falls back to in-memory cache if not set (OK for low traffic).
# Format: rediss://user:password@host:port
REDIS_URL=

# ── Notes ─────────────────────────────────────────────────────
# Email: Handled by Supabase Auth built-in email + in-app notifications.
#        Configure templates: Supabase Dashboard → Auth → Email Templates
#        Configure SMTP:      Supabase Dashboard → Auth → Settings → SMTP
#
# Push notifications: Not used. In-app notifications only.
#
# Payments: UPI (UTR) + Cash only. No external payment gateway.
