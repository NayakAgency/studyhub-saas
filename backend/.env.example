# ============================================================
# StudyHub Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Minimum 32 characters, 48+ recommended for production
JWT_SECRET=generate-a-minimum-32-character-random-string-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Frontend URL — used in notification links and CORS (no trailing slash)
APP_URL=https://studyhub.vercel.app
APP_NAME=StudyHub

# Comma-separated list of allowed CORS origins (no spaces)
# Add your Vercel preview URL too if needed:
# ALLOWED_ORIGINS=https://studyhub.vercel.app,https://studyhub-git-main-yourname.vercel.app
ALLOWED_ORIGINS=https://studyhub.vercel.app

# ── Redis Cache (optional) ────────────────────────────────────
# Falls back to in-memory cache if not set — fine for low traffic.
# Upstash free tier: https://upstash.com
# Format: rediss://user:password@host:port
REDIS_URL=

# ── Notes ─────────────────────────────────────────────────────
# Email:    Handled by Supabase Auth built-in + in-app notifications.
#           Configure SMTP: Supabase Dashboard → Auth → Settings → SMTP
#
# Push:     In-app notifications only (no external push gateway required).
#
# Payments: UPI (UTR verification) + Cash only.
#           No external payment gateway needed.
